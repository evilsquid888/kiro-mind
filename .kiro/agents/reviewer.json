{
  "name": "reviewer",
  "description": "Performance review writing \u2014 self-review, peer review, review briefs, PR scanning",
  "keyboardShortcut": "ctrl+shift+r",
  "welcomeMessage": "Review mode \u2014 self-review, peer review, review brief, or peer-scan?",
  "resources": [
    "file://../../AGENTS.md",
    "file://../steering/**/*.md",
    "skill://../skills/**/SKILL.md"
  ],
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "glob",
    "grep",
    "use_subagent",
    "thinking",
    "todo_list"
  ],
  "allowedTools": [
    "fs_read",
    "glob",
    "grep",
    "thinking",
    "todo_list"
  ],
  "prompt": "file://prompts/reviewer.md",
  "hooks": {
    "agentSpawn": [
      {
        "command": "bash .kiro/scripts/session-start.sh",
        "description": "Inject vault context"
      }
    ],
    "postToolUse": [
      {
        "matcher": "write",
        "command": "python3 .kiro/scripts/validate-write.py",
        "description": "Validate vault notes"
      }
    ]
  },
  "toolsSettings": {
    "subagent": {
      "availableAgents": [
        "review-prep",
        "review-fact-checker",
        "context-loader",
        "brag-spotter"
      ],
      "trustedAgents": [
        "review-prep",
        "review-fact-checker"
      ]
    }
  }
}
