{
  "name": "incident",
  "description": "Incident capture from Slack channels and threads",
  "keyboardShortcut": "ctrl+shift+i",
  "welcomeMessage": "Incident mode \u2014 paste Slack URLs to begin capture.",
  "resources": [
    "file://../../AGENTS.md",
    "file://../steering/**/*.md",
    "skill://../skills/**/SKILL.md"
  ],
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "glob",
    "grep",
    "use_subagent",
    "thinking",
    "todo_list"
  ],
  "allowedTools": [
    "fs_read",
    "glob",
    "grep",
    "thinking",
    "todo_list"
  ],
  "prompt": "file://prompts/incident.md",
  "hooks": {
    "agentSpawn": [
      {
        "command": "bash .kiro/scripts/session-start.sh",
        "description": "Inject vault context"
      }
    ],
    "postToolUse": [
      {
        "matcher": "write",
        "command": "python3 .kiro/scripts/validate-write.py",
        "description": "Validate vault notes"
      }
    ]
  },
  "toolsSettings": {
    "subagent": {
      "availableAgents": [
        "slack-archaeologist",
        "people-profiler",
        "context-loader"
      ],
      "trustedAgents": [
        "slack-archaeologist",
        "people-profiler"
      ]
    }
  }
}
